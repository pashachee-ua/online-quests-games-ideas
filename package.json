{
  "name": "online-quests-games-ideas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Внутренняя витрина идей игровых механик для онлайн-квестов (тимбилдинг)",
  "scripts": {
    "dev": "vite",
    "images:webp": "node scripts/convert-images-to-webp.mjs",
    "build": "tsc --noEmit && vite build",
    "postbuild": "cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.6"
  }
}
